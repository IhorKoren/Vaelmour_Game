    {
      "rule": "Quest Difficulty",
      "value": "Normal / Hard / Elite / Boss",
      "design_notes": "Used for reward scaling."
    },
    {
      "rule": "Quest Reward Types",
      "value": "XP / Gold / Materials / Recipe / Key Item / Reputation",
      "design_notes": "Mix rewards to support crafting and progression."
    },
    {
      "rule": "Quest Tracking",
      "value": "Max 5 normal active quests + 3 dailies",
      "design_notes": "Avoids overloaded UI."
    },
    {
      "rule": "Quest Completion",
      "value": "Claim manually",
