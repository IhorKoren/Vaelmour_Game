  "inventoryRules": [
    {
      "rule": "Base Inventory Slots",
      "value": "30",
      "design_notes": "Enough for Telegram RPG without inventory stress."
    },
    {
      "rule": "Premium/Upgrade Expansion",
      "value": "+10 slots per upgrade, max 80",
      "design_notes": "Can be monetized later but should not be mandatory."
    },
    {
      "rule": "Equipment does not occupy inventory",
      "value": "Equipped items separate",
      "design_notes": "Cleaner UX."
    },
    {
      "rule": "Quest Items",
      "value": "Separate quest inventory",
      "design_notes": "Prevents quest blockers from filling bags."
    },
    {
      "rule": "Materials",
      "value": "Stackable",
      "design_notes": "Core crafting materials stack by rarity."
    },
    {
      "rule": "Weapons/Armor",
      "value": "Non-stackable",
      "design_notes": "Each item can have rarity/affix/quality."
    },
    {
      "rule": "Rings/Talismans",
      "value": "Non-stackable",
      "design_notes": "Build-defining items."
    },
    {
      "rule": "Auto-loot",
      "value": "Enabled by default",
      "design_notes": "But if inventory full, send to temporary loot box."
    },
    {
      "rule": "Temporary Loot Box",
      "value": "24h claim window",
      "design_notes": "Prevents losing rare drops due to full inventory."
    },
    {
      "rule": "Sort Options",
      "value": "By rarity / level / type / newest",
      "design_notes": "Required for mobile UX."
    },
    {
      "rule": "Filters",
      "value": "Weapons / Armor / Materials / Quest / Crafting",
      "design_notes": "Simple category tabs."
    },
    {
      "rule": "Destroy Item",
      "value": "Allowed for Common+",
      "design_notes": "Confirm for Rare+."
    }
  ],
