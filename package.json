{
  "name": "racing",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx watch server/index.ts",
    "start:server": "node dist-server/server/index.js",
    "test": "npm run test:projection && npm run test:camera && npm run test:server",
    "test:camera": "node --import tsx --test src/client/game/camera/cameraConfig.test.ts",
    "test:projection": "node --import tsx --test src/client/game/rendering/projection.test.ts",
    "test:server": "node --import tsx --test server/multiplayerServer.test.ts",
    "build:server": "tsc -b tsconfig.server.json",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint . --max-warnings=0",
    "preview": "vite preview"
  },
  "dependencies": {
    "phaser": "^3.90.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "ws": "^8.21.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@types/node": "^22.19.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.0",
    "eslint": "^9.39.0",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-react-refresh": "^0.5.0",
    "globals": "^16.5.0",
    "tsx": "^4.23.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.0",
    "vite": "^8.0.0"
  }
}
